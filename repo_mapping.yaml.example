# Repo-Vault Mapping Configuration
#
# This file maps Obsidian vault folders to local git repositories,
# GitHub repos, and Jira projects. The agent uses this to connect
# your Second Brain notes to your active development work.
#
# Usage:
#   1. Copy this file to `repo_mapping.yaml`
#   2. Update the paths and identifiers for your projects
#   3. Run: obsidian-mcp --load-mappings

mappings:
  # Example: A project with GitHub and Jira integration
  - vault_path: "10_Projects/ProjectAlpha"
    repo_path: "~/Projects/project-alpha"
    github: "your-org/project-alpha"
    jira_project: "PA"
    description: "My primary development project"
    active: true

  # Example: A project with GitHub only (no Jira)
  - vault_path: "10_Projects/ProjectBeta"
    repo_path: "~/Projects/project-beta"
    github: "your-org/project-beta"
    jira_project: null
    description: "Side project or open source contribution"
    active: true

  # Example: A local-only project (no GitHub or Jira)
  - vault_path: "10_Projects/PersonalDashboard"
    repo_path: "~/Projects/personal-dashboard"
    github: null
    jira_project: null
    description: "Personal productivity tracking dashboard"
    active: false

# Notes:
# - vault_path: Relative to vault root (e.g., "10_Projects/MyProject")
# - repo_path: Absolute path or ~/ path to local git repo
# - github: Format "owner/repo" or null if not on GitHub
# - jira_project: Jira project key (e.g., "PA", "PROJ") or null
# - active: Set to false to exclude a project from pulse scans
