# Obsidian MCP Configuration
# Copy this to .env and modify as needed

# Path to your Obsidian vault
VAULT_PATH=~/Projects/project-sb

# Path to SQLite database (inside vault's .obsidian folder)
DB_PATH=~/Projects/project-sb/.obsidian/vault_graph.db

# Gemini model for indexing (gemini-2.5-flash recommended for speed/cost)
GEMINI_MODEL=gemini-2.5-flash

# Batch size in characters for LLM indexing (25000 = ~25KB)
BATCH_SIZE=25000

# Journal folder relative to vault root
JOURNAL_FOLDER=50_Journal

# Journal date format (Python strftime)
JOURNAL_DATE_FORMAT=%Y-%m-%d

# Jira base URL for ticket links in pulse scans (optional)
# JIRA_BASE_URL=https://your-org.atlassian.net

# =============================================================================
# LLM PROVIDER
# =============================================================================

# AI provider for indexing and intelligence: gemini (default), claude, openai
# LLM_PROVIDER=gemini

# Model override — if not set, provider-specific defaults apply:
#   gemini -> value of GEMINI_MODEL (or gemini-2.5-flash)
#   claude -> claude-sonnet-4-5
#   openai -> gpt-4o-mini
# LLM_MODEL=gemini-2.5-flash

# OpenAI API key — required when LLM_PROVIDER=openai
# Also run: pip install 'obsidian-mcp[openai]'
# OPENAI_API_KEY=sk-...
